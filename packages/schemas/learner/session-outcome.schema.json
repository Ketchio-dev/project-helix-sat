{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://helixsat.dev/schemas/learner/session-outcome.schema.json",
  "title": "Session Outcome",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "sessionId",
    "sessionType",
    "completedAt",
    "headline",
    "subheadline",
    "statusPill",
    "metrics",
    "evidenceBullets",
    "nextStep",
    "primaryAction"
  ],
  "properties": {
    "sessionId": {
      "type": "string",
      "minLength": 1
    },
    "sessionType": {
      "enum": [
        "quick_win",
        "timed_set",
        "module_simulation"
      ]
    },
    "completedAt": {
      "type": [
        "string",
        "null"
      ]
    },
    "headline": {
      "type": "string",
      "minLength": 1
    },
    "subheadline": {
      "type": "string",
      "minLength": 1
    },
    "statusPill": {
      "type": "string",
      "minLength": 1
    },
    "metrics": {
      "type": "array",
      "items": {
        "type": "array",
        "minItems": 2,
        "maxItems": 2,
        "items": {
          "type": "string"
        }
      }
    },
    "evidenceBullets": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "nextStep": {
      "type": [
        "string",
        "null"
      ]
    },
    "primaryAction": {
      "type": [
        "object",
        "null"
      ],
      "additionalProperties": false,
      "required": [
        "kind",
        "title",
        "reason",
        "ctaLabel",
        "estimatedMinutes",
        "sessionType",
        "section"
      ],
      "properties": {
        "kind": {
          "enum": [
            "complete_goal_setup",
            "start_diagnostic",
            "start_quick_win",
            "resume_active_session",
            "review_mistakes",
            "start_retry_loop",
            "start_timed_set",
            "start_module"
          ]
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "reason": {
          "type": "string",
          "minLength": 1
        },
        "ctaLabel": {
          "type": "string",
          "minLength": 1
        },
        "estimatedMinutes": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 1
        },
        "sessionType": {
          "type": [
            "string",
            "null"
          ],
          "enum": [
            "diagnostic",
            "quick_win",
            "review",
            "timed_set",
            "module_simulation",
            null
          ]
        },
        "section": {
          "type": [
            "string",
            "null"
          ],
          "enum": [
            "reading_writing",
            "math",
            null
          ]
        },
        "itemId": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        },
        "focusSkill": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        },
        "profileLabel": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        },
        "profileStory": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        },
        "realismProfile": {
          "type": [
            "string",
            "null"
          ],
          "enum": [
            "standard",
            "extended",
            "exam",
            null
          ]
        },
        "itemCount": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 1
        },
        "structureBreakpoints": {
          "type": [
            "array",
            "null"
          ],
          "items": {
            "type": "integer",
            "minimum": 1
          }
        },
        "timeLimitSec": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 60
        },
        "recommendedPaceSec": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 1
        },
        "studentResponseTarget": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 1
        }
      }
    }
  }
}
