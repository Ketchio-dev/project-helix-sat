{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://helixsat.dev/schemas/tutor/error-diagnosis.schema.json",
  "title": "Tutor Error Diagnosis",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "issue_type",
    "confidence",
    "evidence",
    "recommended_intervention",
    "followup_skill",
    "should_schedule_followup"
  ],
  "properties": {
    "issue_type": {
      "type": "string"
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "evidence": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1
    },
    "recommended_intervention": {
      "type": "string"
    },
    "followup_skill": {
      "type": "string"
    },
    "metacognitive_note": {
      "type": "string"
    },
    "should_schedule_followup": {
      "type": "boolean"
    }
  }
}
