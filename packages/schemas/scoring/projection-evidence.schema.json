{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://helixsat.dev/schemas/scoring/projection-evidence.schema.json",
  "title": "Projection Evidence",
  "type": "object",
  "additionalProperties": false,
  "required": ["band", "confidence", "signalLabel", "signalExplanation", "momentum", "readiness", "status", "whyChanged"],
  "properties": {
    "band": {
      "type": "object",
      "additionalProperties": false,
      "required": ["low", "high", "rwLow", "rwHigh", "mathLow", "mathHigh"],
      "properties": {
        "low": { "type": "integer", "minimum": 400, "maximum": 1600 },
        "high": { "type": "integer", "minimum": 400, "maximum": 1600 },
        "rwLow": { "type": "integer", "minimum": 200, "maximum": 800 },
        "rwHigh": { "type": "integer", "minimum": 200, "maximum": 800 },
        "mathLow": { "type": "integer", "minimum": 200, "maximum": 800 },
        "mathHigh": { "type": "integer", "minimum": 200, "maximum": 800 }
      }
    },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "signalLabel": { "type": "string", "enum": ["early estimate", "building signal", "stable signal"] },
    "signalExplanation": { "type": "string", "minLength": 1 },
    "momentum": { "type": "number", "minimum": 0, "maximum": 1 },
    "readiness": {
      "type": "string",
      "enum": ["insufficient_evidence", "needs_foundation", "building", "approaching_goal", "test_ready"]
    },
    "status": {
      "type": "string",
      "enum": ["insufficient_evidence", "low_evidence", "sufficient"]
    },
    "whyChanged": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    }
  }
}
