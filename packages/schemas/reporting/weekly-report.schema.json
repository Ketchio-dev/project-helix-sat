{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://helixsat.dev/schemas/reporting/weekly-report.schema.json",
  "title": "Weekly Report",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "periodStart",
    "periodEnd",
    "strengths",
    "risks",
    "recommendedFocus",
    "completionStreak",
    "nextWeekOpportunity"
  ],
  "properties": {
    "periodStart": {
      "type": "string",
      "format": "date"
    },
    "periodEnd": {
      "type": "string",
      "format": "date"
    },
    "strengths": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "risks": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "recommendedFocus": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "completionStreak": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "current",
        "best",
        "lastCompletedDate",
        "activeToday",
        "atRisk",
        "headline",
        "prompt"
      ],
      "properties": {
        "current": {
          "type": "integer",
          "minimum": 0
        },
        "best": {
          "type": "integer",
          "minimum": 0
        },
        "lastCompletedDate": {
          "type": ["string", "null"],
          "format": "date"
        },
        "activeToday": {
          "type": "boolean"
        },
        "atRisk": {
          "type": "boolean"
        },
        "headline": {
          "type": "string"
        },
        "prompt": {
          "type": "string"
        }
      }
    },
    "nextWeekOpportunity": {
      "type": "string"
    },
    "projectedMomentum": {
      "type": "string",
      "enum": [
        "declining",
        "flat",
        "improving",
        "strong"
      ]
    },
    "parentSummary": {
      "type": "string"
    },
    "teacherBrief": {
      "type": "string"
    }
  }
}
