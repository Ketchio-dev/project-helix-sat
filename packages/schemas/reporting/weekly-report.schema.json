{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://helixsat.dev/schemas/reporting/weekly-report.schema.json",
  "title": "Weekly Report",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "period_start",
    "period_end",
    "strengths",
    "risks",
    "recommended_focus",
    "completion_streak",
    "next_week_opportunity"
  ],
  "properties": {
    "period_start": {
      "type": "string",
      "format": "date"
    },
    "period_end": {
      "type": "string",
      "format": "date"
    },
    "strengths": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "risks": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "recommended_focus": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "completion_streak": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "current",
        "best",
        "lastCompletedDate",
        "activeToday",
        "atRisk",
        "headline",
        "prompt"
      ],
      "properties": {
        "current": {
          "type": "integer",
          "minimum": 0
        },
        "best": {
          "type": "integer",
          "minimum": 0
        },
        "lastCompletedDate": {
          "type": ["string", "null"],
          "format": "date"
        },
        "activeToday": {
          "type": "boolean"
        },
        "atRisk": {
          "type": "boolean"
        },
        "headline": {
          "type": "string"
        },
        "prompt": {
          "type": "string"
        }
      }
    },
    "next_week_opportunity": {
      "type": "string"
    },
    "projected_momentum": {
      "type": "string",
      "enum": [
        "declining",
        "flat",
        "improving",
        "strong"
      ]
    },
    "parent_summary": {
      "type": "string"
    },
    "teacher_brief": {
      "type": "string"
    }
  }
}
