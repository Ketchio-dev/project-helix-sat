{
  "name": "project-helix-sat",
  "private": true,
  "version": "0.1.0",
  "description": "Foundation workspace for Project Helix SAT",
  "type": "module",
  "workspaces": [
    "apps/*",
    "services/*",
    "packages/*"
  ],
  "scripts": {
    "start": "node services/api/server.mjs",
    "dev": "node services/api/server.mjs",
    "build": "node scripts/build.mjs",
    "check": "node scripts/validate-foundation.mjs && npm run build && node --test",
    "check:schemas": "node scripts/validate-foundation.mjs",
    "test": "node --test"
  },
  "engines": {
    "node": ">=22"
  }
}
